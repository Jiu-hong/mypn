# option1:
sudo global-state-update-gen generic \
 -d /var/lib/casper/casper-node/mynetwork \
 -s efc63494734b733665d757bca8825813ac0a83dbfee2767f4e601f6ee841b9eb \
 config.toml > global_state.toml

