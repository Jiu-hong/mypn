# compress database on source machine
rm ~/file.tar.zst
cd /var/lib/casper/casper-node/mynetwork
tar -b 4096 -cv --sparse . | zstd -5 -cv -T0 --long=31 > ~/file.tar.zst

# decompress database on target machine
cd /var/lib/casper/casper-node/mynetwork
sudo rm -rf *
zstd -cd --long=31 ~/file.tar.zst  | sudo -u casper tar -xv


# get tool

# get global-state-update-gen json info

curl "https://genesis.casper.network/artifacts/casper-node/$(curl https://genesis.casper.network/artifacts/casper-node/dev.latest)/version.json"

# get global-state-update-gen binary

curl -JLO "https://genesis.casper.network/artifacts/casper-node/$(curl https://genesis.casper.network/artifacts/casper-node/dev.latest)/global-state-update-gen_0.3.0_amd64.deb"

<!-- install global-state-update-gen -->

sudo dpkg -i global-state-update-gen_0.3.0_amd64.deb && global-state-update-gen --help

